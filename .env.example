# Market Environment (optional)
MARKET_ENV_API_KEY=your_market_env_api_key_here

# Financial Modeling Prep (FMP) API
FMP_API_KEY=your_fmp_api_key_here

# App Settings
LOG_LEVEL=INFO
REPORT_OUTPUT_DIR=./reports
